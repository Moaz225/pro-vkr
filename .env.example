## BRODSKY — Environment variables template (.env.example)
## Copy this file to `.env` and fill in real values.
## WARNING: NEVER commit your real `.env` to Git (it contains secrets).

##
## App / Runtime
##
# NODE_ENV — runtime mode.
# - Use `production` on Render/real hosting.
# - Use `development` locally.
NODE_ENV=production

# PORT — HTTP port the server listens on.
# - On Render: Render sets PORT automatically (do not hardcode in Render).
# - Locally: can be 3000.
PORT=3000

# TRUST_PROXY — set to 1 when running behind a reverse proxy (Render, ngrok, etc.).
# Required for correct client IP detection and secure cookies behind proxies.
TRUST_PROXY=1

# CORS_ORIGIN — allowed frontend origin(s) for browser requests.
# - Production: MUST be an explicit allowlist (no "*").
# - Can be comma-separated, e.g.:
#   CORS_ORIGIN=https://brodsky.onrender.com,https://admin.brodsky.example
# - Typically equals PUBLIC_BASE_URL if frontend and backend are on same domain.
CORS_ORIGIN="https://brodsky.onrender.com"

##
## Database (Prisma)
##
# DATABASE_URL — PostgreSQL connection string.
# On Render, you will get it from the managed Postgres service (Internal Database URL).
# Format example:
#   postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/brodsky?schema=public"

##
## Public base URL (used to build YooKassa return/webhook URLs)
##
# PUBLIC_BASE_URL — public HTTPS base URL of the deployed app.
# Used by backend to build YooKassa return URLs.
# - Production MUST be https:// (validated in `server/env.js`).
# Examples:
#   PUBLIC_BASE_URL="https://brodsky.onrender.com"
#   PUBLIC_BASE_URL="https://xxxx.ngrok-free.dev" (local webhook testing)
PUBLIC_BASE_URL="https://brodsky.onrender.com"

##
## YooKassa
##
# YOOKASSA_SHOP_ID — YooKassa shop identifier.
# Get it from your YooKassa merchant account settings.
YOOKASSA_SHOP_ID="YOUR_SHOP_ID"

# YOOKASSA_SECRET_KEY — YooKassa secret API key.
# Get it from YooKassa (test keys for test environment, live keys for production).
YOOKASSA_SECRET_KEY="YOUR_SECRET_KEY"

# YOOKASSA_CURRENCY — currency code used for payments (default RUB).
YOOKASSA_CURRENCY="RUB"

##
## Sessions / cookies
##
# SESSION_SECRET — secret for signing Express session cookies.
# MUST be a strong random string (>= 32 chars) in production.
# Example:
#   SESSION_SECRET="b8f0c2c4f2f24b6f8c71c7f8a1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9"
SESSION_SECRET="CHANGE_ME_MIN_32_CHARS"

# CSRF_SECRET — reserved for future cookie-based CSRF mode.
# Current implementation uses session-based CSRF via `csurf()` and does not require this variable.
CSRF_SECRET="CHANGE_ME_MIN_32_CHARS"

# Cookie security flags (Phase 5):
# - In production behind HTTPS, COOKIE_SECURE should be 1.
COOKIE_SECURE=1
